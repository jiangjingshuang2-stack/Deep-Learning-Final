% Lightweight local NeurIPS-style template for course submission.
% It follows the visual conventions of NeurIPS papers: two-column-free
% article layout, title block, abstract, compact margins, and section style.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 Lightweight NeurIPS style]

\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{natbib}
\RequirePackage{abstract}
\RequirePackage{etoolbox}

\geometry{letterpaper, margin=1in}
\pagestyle{fancy}
\setlength{\headheight}{14pt}
\fancyhf{}
\rhead{\thepage}
\lhead{Deep Learning and Spatial Intelligence Final Project}
\renewcommand{\headrulewidth}{0.4pt}

\titleformat{\section}{\large\bfseries}{\thesection}{0.6em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{0.6em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{0.6em}{}
\titlespacing*{\section}{0pt}{1.4ex plus .4ex minus .2ex}{0.8ex}
\titlespacing*{\subsection}{0pt}{1.0ex plus .3ex minus .2ex}{0.5ex}

\renewcommand{\abstractnamefont}{\normalfont\bfseries}
\renewcommand{\abstracttextfont}{\normalfont\small}
\setlength{\absleftindent}{0.8cm}
\setlength{\absrightindent}{0.8cm}
\setlength{\abstitleskip}{-0.5em}

\renewcommand{\maketitle}{%
  \begin{center}
    {\LARGE\bfseries \@title \par}
    \vskip 0.8em
    {\large \@author \par}
    \vskip 0.3em
    {\small \@date \par}
  \end{center}
  \vskip 0.8em
}

\setlength{\parindent}{0pt}
\setlength{\parskip}{0.45em}
\setlength{\textfloatsep}{1.0em plus 0.2em minus 0.2em}
\setlength{\floatsep}{0.8em plus 0.2em minus 0.2em}
\setlength{\intextsep}{0.8em plus 0.2em minus 0.2em}
